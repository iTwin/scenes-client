{
  "name": "scenes-client-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test:client": "pnpm --filter scenes-client test",
    "test:client:unit": "pnpm --filter scenes-client test:unit",
    "test:client:integration": "pnpm --filter scenes-client test:integration",
    "lint:client": "pnpm --filter scenes-client lint",
    "build:client": "pnpm --filter scenes-client build",
    "typecheck:client": "pnpm --filter scenes-client typecheck"
  },
  "engines": {
    "pnpm": ">=10.30.1",
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "tmp@<=0.2.3": ">=0.2.4",
      "picomatch@<2.3.2": "^2.3.2",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@changesets/types": "6.0.0",
    "typescript": "^5.8.3"
  }
}
